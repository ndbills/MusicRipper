# Audio output (never commit ripped media)
*.flac
*.wav
*.ape
*.cue
*.m4a
*.mp3

# Local runtime artifacts (logs go to %LOCALAPPDATA%\MusicRipper\logs\, but if
# anyone runs the tool from inside the repo we still want to ignore stray logs).
*.log
logs/

# Per-machine, secret-bearing config; only the template is committed.
config.json
config/config.json
credentials.clixml
*.clixml

# OS / editor cruft
Thumbs.db
desktop.ini
.DS_Store
.vs/
.vscode/
*.user

# Generated shortcut at the repo root. .lnk files store absolute paths
# baked in at creation time, so a committed shortcut would be stale on
# any machine cloning to a different path. setup/Install-UninstallShortcut.ps1
# regenerates it (and Install-MusicRipper.ps1 chains that as part of the
# install flow).
Uninstall MusicRipper.lnk

# Temp / build
tmp/
temp/
out/
dist/
testResults.xml

pester-result.txt
